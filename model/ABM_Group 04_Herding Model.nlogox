<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[;; =============================================================
;; FM 4054 Agent-Based Modeling | University of Colombo
;; Group 04
;; Analyzing the Impact of Social Media Sentiment on Investor Herding Behavior in Financial Markets Using Agent-Based Modeling
;;
;; Input Files Required (place in same folder as this .nlogo):
;;   1. daily_sentiment_with_btc.csv  — 36 daily sentiment scores
;;   2. tweet_agents.csv              — 360 individual tweet records
;; =============================================================



extensions [ csv ]
;; The CSV extension allows NetLogo to read external .csv files.
;; It must be declared before any other code.

;; ─────────────────────────────────────────────────────────────
;; AGENT BREEDS
;; NetLogo requires all custom agent types to be declared here.
;; ─────────────────────────────────────────────────────────────
breed [ investors investor ]
;; investor agents represent financial market participants.
;; They appear as "person" shapes in the world view.
;; 100 investors are created at setup

breed [ tweets tweet ]
;; tweet agents represent individual social media posts.
;; They appear as circles in the world view.
;; Up to 10 tweet agents are created per trading day (tick)
;; from real FinBERT-scored data in tweet_agents.csv.
;; Old tweet agents shrink over time and die after tweet-lifespan ticks.

;; ─────────────────────────────────────────────────────────────
;; GLOBAL VARIABLES
;; Variables shared across all agents and procedures.
;; ─────────────────────────────────────────────────────────────
globals [
  price                          ;; Current market price Pt. Starts at initial-price.
  price-fundamental              ;; Intrinsic asset value P^f. Used by Fundamentalists.Performs a small random walk each tick.
  sentiment-score                ;; Global daily sentiment St ∈ [−1, 1].Computed as the influence-weighted average of all active tweet agents each tick.
  avg-local-sentiment
  all-tweet-data                 ;; Full list of rows loaded from tweet_agents.csv. Each row contains: tick, sentiment, reach, engagement.
  date-list                      ;; List of date strings from daily_sentiment_with_btc.csv. Used only for the "Date" monitor display.
  buyers-count                   ;; Number of investors with demand > 0 this tick (Bt)
  sellers-count                  ;; Number of investors with demand < 0 this tick.
  herding-index                  ;; Market coordination measure: |Bt − sellers| / N. Ranges from 0 (balanced) to 1 (extreme herding).
  current-return                 ;; Price return this tick: (Pt − Pt-1) / Pt-1. 
  previous-price                 ;; Market price from the previous tick. Used to calculate current-return each tick. 
  volatility                     ;; Absolute value of current-return: |current-return|.
  average-return                 ;; Running mean of all returns across the simulation.
  market-data                    ;; List of rows loaded from daily_sentiment_with_btc.csv. Each row: date, St, tick, tweet_count, btc_close.
  data-index                     ;; Pointer tracking which row of market-data to read next. Increments by 1 each tick in dataset scenario.
  data-exhausted?                ;; Boolean flag. Becomes true after all 36 dates are
] 


;; ─────────────────────────────────────────────────────────────
;; INVESTOR AGENT PROPERTIES
;; Each investor owns these variables independently.
;; ─────────────────────────────────────────────────────────────
investors-own [
  agent-type    ;; Investor classification string:
                ;;   "F"  = Fundamentalist — trades toward intrinsic value P^f,ignores sentiment entirely, stabilises the market.         
                ;;   "C+" = Chartist Optimist — buys when sentiment is positive, amplifies the crowd direction (herding driver)         
                ;;   "C-" = Chartist Pessimist — contrarian to C+, sells when  sentiment is positive, but still affected by herding.     

  gamma-i       ;; Individual sentiment sensitivity coefficient. Drawn uniformly from [0.2, 0.9] at setup.
                ;; Higher gamma-i = stronger reaction to tweet agents.
                ;; Models heterogeneity — not all investors respond equally.
  
  wealth        ;; Current wealth in USD. Initialised at $10,000. 
  
  shares        ;; Number of shares currently held. Initialised at 10.
  
  demand        ;; Computed demand value for this tick.
                ;; Positive demand → investor buys (color = green).
                ;; Negative demand → investor sells (color = red).
                
  local-sentiment ;; Sentiment this investor perceives from nearby tweet agents.Computed as the influence-weighted average of all tweets 
                  ;; within vision-radius patches. If no nearby tweets exist,local-sentiment decays toward 0 by a factor of 0.5.

]


;; ─────────────────────────────────────────────────────────────
;; TWEET AGENT PROPERTIES
;; Each tweet agent carries data from a real FinBERT-scored tweet.
;; ─────────────────────────────────────────────────────────────
tweets-own [
  tweet-sentiment                ;; FinBERT sentiment score for this individual tweet.
                                 ;; Range: [−1, 1]. Computed as P(positive) − P(negative).
                                 ;; Positive = bullish language. Negative = bearish language.
   
  tweet-reach                    ;; Normalised follower count of the tweet's author. [0, 1].
                                 ;; Higher reach = more investors can see this tweet
                                 ;; (probability of exposure = tweet-reach).
  
  tweet-engagement               ;; Normalised engagement score (likes + retweets). [0, 1].
                                 ;; Higher engagement = tweet was more viral/impactful.
  
  tweet-influence                ;; Combined impact weight = tweet-reach × tweet-engagement.
                                 ;; Used to weight this tweet's contribution to local-sentiment
                                 ;; and to determine the agent's size in the world view.
 
  age                            ;; Number of ticks since this tweet was spawned.
                                 ;; Increases by 1 each tick. When age >= tweet-lifespan,
                                 ;; the tweet agent dies (simulating news becoming irrelevant).
  
  tick-born                      ;; The tick at which this tweet was created.
                                 ;; Stored for reference; not used in calculations.
]


;; =============================================================
;; SETUP PROCEDURE
;; Resets the entire simulation and loads input data.
;; =============================================================
to setup
  clear-all

  set price               initial-price             ;; Set starting price from slider
  set price-fundamental   initial-price             ;; Fundamental value starts equal to price
  set previous-price      initial-price             ;; Previous price also starts at initial-price
  set sentiment-score     0                         ;; S0 = 0 (neutral sentiment at start)
  set avg-local-sentiment 0
  set buyers-count        0
  set sellers-count       0
  set herding-index       0
  set current-return      0
  set volatility          0
  set average-return      0
  set data-index          1                         ;; Start reading from row 1 (skip header)
  set data-exhausted?     false                     ;; Simulation has not finished yet


;; ── Load both CSV input files into memory ────────────────
  load-sentiment-data                       ;; Reads daily_sentiment_with_btc.csv
  load-tweet-agents                         ;; Reads tweet_agents.csv

  
;; ── Create 100 investor agents ───────────────────────────  
  create-investors num-investors [
    setxy random-xcor random-ycor
    set wealth          10000
    set shares          10
    set gamma-i         0.2 + random-float 0.7              ;; Random sensitivity [0.2, 0.9]
    set local-sentiment 0                                   ;; No sentiment perceived yet
    set demand          0

    let roll random 100
    ifelse roll < num-fundamentalists [
      ;; This investor is a Fundamentalist
      set agent-type "F"
      set color blue
    ] [
      ;; This investor is a Chartist — randomly optimist or pessimist
      ifelse random 2 = 0 [
        set agent-type "C+"       ;; Chartist Optimist
        set color yellow
      ] [
        set agent-type "C-"       ;; Chartist Pessimist
        set color orange
      ]
    ]

    set shape "person"
    set size 0.9
  ]

  reset-ticks                     ;; Reset tick counter to 0 and trigger initial plot updates.
end


;; =============================================================
;; LOAD-SENTIMENT-DATA
;; Reads daily_sentiment_with_btc.csv and stores all rows in
;; market-data. Also extracts date strings for the Date monitor.
;; =============================================================
to load-sentiment-data
  ifelse file-exists? "daily_sentiment_with_btc.csv" [
    ;; Read all rows into a list of lists
    set market-data csv:from-file "daily_sentiment_with_btc.csv"
    ;; Remove the header row (row 0) — keep only data rows
    set market-data but-first market-data
    ;; Extract the date column (column 0) for monitor display
    set date-list []
    foreach market-data [ row ->
      set date-list lput (item 0 row) date-list
    ]
  ] [
    ;; File not found — alert the user
    user-message "daily_sentiment_with_btc.csv not found. Place it in the same folder as this .nlogo file."
    set market-data []
    set date-list []
  ]
end


;; =============================================================
;; LOAD-TWEET-AGENTS
;; Reads tweet_agents.csv and stores all rows in all-tweet-data.
;; Columns: tick | tweet_sentiment | reach | engagement
;; 360 rows total (36 dates × 10 tweets per date).
;; =============================================================
to load-tweet-agents
  ifelse file-exists? "tweet_agents.csv" [
    set all-tweet-data csv:from-file "tweet_agents.csv"
    ;; Remove the header row
    set all-tweet-data but-first all-tweet-data
  ] [
    user-message "tweet_agents.csv not found. Place it in the same folder as this .nlogo file."
    set all-tweet-data []
  ]
end


;; =============================================================
;; GO PROCEDURE
;; One tick = one trading day in the dataset.
;; =============================================================
to go
  ;; ── Stop condition for dataset scenario ───────────────────
  ;; After all 36 dates are processed, stop automatically.
  if scenario = "dataset" and data-exhausted? [ stop ]

  ;; ── Step 1: Update global sentiment from chosen scenario ──
  update-external-sentiment
  
  ;; ── Step 2: Spawn today's tweet agents ───────────────────
  ;; Dataset mode: use real FinBERT data from tweet_agents.csv.
  ;; Other modes: generate tweets dynamically around global St.
  ifelse scenario = "dataset" [
    spawn-todays-tweets (ticks + 1)
    ;; ticks + 1 because tick column in CSV is 1-indexed
    ;; (tick 1 = first date, tick 36 = last date)
  ] [
    spawn-dynamic-tweets
  ]

  ;; ── Step 3: Age all existing tweet agents ────────────────
  ;; Tweets grow older each tick and eventually die.
  age-tweets
  
  ;; ── Step 4: Each investor reads nearby tweet agents ──────
  ;; Investors only see tweets within their vision-radius.
  ;; This models the fact that not everyone sees the same posts.
  read-local-sentiment

  ;; ── Step 5: Random walk in fundamental value ─────────────
  ;; P^f drifts slightly each tick (±0.5) to prevent the market
  ;; from becoming completely static in Fundamentalist-dominated runs.
  set price-fundamental price-fundamental + (random-float 1 - 0.5) * 0.5

  ;; ── Step 6: Every investor computes demand and decides ───
  ask investors [ decide ]
  
  ;; ── Step 7: Count buyers and sellers ─────────────────────
  set buyers-count  count investors with [ demand > 0 ]
  set sellers-count count investors with [ demand < 0 ]
  
  ;; ── Step 8: Update market price ──────────────────────────
  ;; Price update rule: Pt+1 = Pt + α × (Bt − sellers)
  ;; α = price-sensitivity slider (default 0.05)
  ;; Excess buyers push price up; excess sellers push price down.
  ;; max list 1 prevents price from going below $1.
  set previous-price price
  set price max list 1 (price + price-sensitivity * (buyers-count - sellers-count))

  ;; ── Step 9: Compute output measures ──────────────────────
  update-output-measures

  ;; ── Step 10: Update investor colours ─────────────────────
  ;; Green = buying, Red = selling.
  ;; Holding investors show their type colour (Blue/Yellow/Orange).
  ask investors [
    ifelse demand > 0 [
      set color green                                 ;; Actively buying
    ] [
      ifelse demand < 0 [
        set color red                                 ;; Actively selling
      ] [
        ;; Holding — restore type-specific colour
        if agent-type = "F"  [ set color blue   ]
        if agent-type = "C+" [ set color yellow ]
        if agent-type = "C-" [ set color orange ]
      ]
    ]
  ]

  tick
  ;; Advance the tick counter by 1 and trigger pen update commands
  
end


;; =============================================================
;; GO-ONCE
;; Runs exactly one tick. Useful for step-by-step inspection.
;; =============================================================
to go-once
  go
end


;; =============================================================
;; UPDATE-EXTERNAL-SENTIMENT
;; Sets the global sentiment-score based on the chosen scenario.
;; Called at the beginning of each tick in go.
;; =============================================================
to update-external-sentiment
  if scenario = "dataset" [
    ;; Read the next row from market-data (one row per tick).
    ;; Column 1 = St (the daily FinBERT weighted average score).
    ifelse data-index <= length market-data [
      let row item (data-index - 1) market-data
      set sentiment-score item 1 row                     ;; Column 1 = St
      set data-index data-index + 1                      ;; Advance to next row
    ] [
      ;; All 36 dates have been read — flag the simulation to stop
      set data-exhausted? true
    ]
  ]

  if scenario = "baseline" [
    ;; No social media influence at all.
    ;; This is the control group — used to establish a reference floor.
    ;; Any herding in other scenarios beyond this level is attributable to sentiment.
    set sentiment-score 0
  ]

  if scenario = "sentiment-shock" [
    ;; Scripted extreme event:
    ;;   Ticks  0–49:  Calm period (no sentiment)
    ;;   Ticks 50–99:  Positive hype wave (+0.8)
    ;;   Ticks 100+:   Crash narrative (−0.6)
    ;; Tests whether the model reacts correctly to a large, sudden sentiment shift. Validates fat tails and volatility clustering.
    if ticks < 50 [ set sentiment-score 0 ]
    if ticks >= 50 and ticks < 100 [ set sentiment-score 0.8 ]
    if ticks >= 100 [ set sentiment-score -0.6 ]
  ]

  if scenario = "random-sentiment" [
    ;; Fresh random St every tick — pure noise with no structure.
    ;; Used to compare against real dataset results.
    ;; If dataset and random-sentiment produce similar statistics, it suggests the real St values are too mild to stand out above random noise.
    set sentiment-score random-float 2 - 1
  ]
end

;; =============================================================
;; SPAWN-TODAYS-TWEETS
;; Creates tweet agents from tweet_agents.csv for a given tick.
;; Only called in dataset scenario. Each matching row in the CSV becomes one tweet agent in the world.
;; =============================================================
to spawn-todays-tweets [ today-tick ]
  ;; Scan all stored tweet rows and create agents for today's date
  foreach all-tweet-data [ row ->
    let row-tick       item 0 row                    ;; Column 0: which simulation day
    let row-sentiment  item 1 row                    ;; Column 1: FinBERT score ∈ [−1, 1]
    let row-reach      item 2 row                    ;; Column 2: normalised reach [0, 1]
    let row-engagement item 3 row                    ;; Column 3: normalised engagement [0, 1]

    if row-tick = today-tick [
      ;; This row belongs to today — create a tweet agent for it
      create-tweets 1 [
        set tweet-sentiment  row-sentiment
        set tweet-reach      row-reach
        set tweet-engagement row-engagement
        set tweet-influence  row-reach * row-engagement
        ;; influence = reach × engagement. High influence tweets appear larger and contribute more to local-sentiment.
        
        set age              0                              ;; Just born
        set tick-born        ticks
        set shape            "circle"
        set size             0.5 + tweet-influence * 2     ;; Size is proportional to influence. More influential tweets appear as larger circles.

        setxy random-xcor random-ycor
        
        ;; Colour by sentiment direction:
        ;;   Pink   = positive (tweet-sentiment > 0.05)
        ;;   Orange = negative (tweet-sentiment < −0.05)
        ;;   Gray   = neutral  (between −0.05 and +0.05)
        ifelse tweet-sentiment > 0.05 [
          set color pink
        ] [
          ifelse tweet-sentiment < -0.05 [
            set color orange
          ] [
            set color white
          ]
        ]
      ]
    ]
  ]
end


;; =============================================================
;; SPAWN-DYNAMIC-TWEETS
;; Creates tweet agents synthetically for non-dataset scenarios.
;; Each tweet is centred around the current global sentiment-score with ±0.2 random variation. Used in baseline, sentiment-shock, and random-sentiment scenarios.
;; =============================================================
to spawn-dynamic-tweets
  create-tweets tweets-per-day [
    ;; Sentiment varies slightly around today's global St
    set tweet-sentiment  sentiment-score + (random-float 0.4 - 0.2)
     ;; Clamp to valid range [−1, 1]
    if tweet-sentiment >  1 [ set tweet-sentiment  1 ]
    if tweet-sentiment < -1 [ set tweet-sentiment -1 ]
    ;; Assign random reach and engagement for synthetic tweets
    set tweet-reach      0.3 + random-float 0.7
    set tweet-engagement 0.3 + random-float 0.7
    set tweet-influence  tweet-reach * tweet-engagement
    set age              0
    set tick-born        ticks
    set shape            "circle"
    set size             0.6

    setxy random-xcor random-ycor

    ;; Apply same colour scheme as real tweet agents
    ifelse tweet-sentiment > 0.05 [
      set color pink
    ] [
      ifelse tweet-sentiment < -0.05 [
        set color orange
      ] [
        set color gray
      ]
    ]
  ]
end


;; =============================================================
;; AGE-TWEETS
;; Called every tick. Increases each tweet's age, shrinks its visual size proportionally, and removes it when it expires.
;; Models the real-world phenomenon of news losing relevance.
;; ============================================================
to age-tweets
  ask tweets [
    set age age + 1
    ;; life-fraction decreases from 1.0 (just spawned) toward 0.1 as the tweet approaches its maximum age.
    let life-fraction 1 - (age / tweet-lifespan)
    if life-fraction < 0.1 [ set life-fraction 0.1 ]
    ;; Shrink the circle as it ages
    set size (0.5 + tweet-influence * 2) * life-fraction
    ;; Remove the tweet when it has exceeded its lifespan
    if age >= tweet-lifespan [ die ]
  ]
end


;; =============================================================
;; READ-LOCAL-SENTIMENT
;; Each investor reads the tweet agents within their vision-radius and forms a weighted average sentiment (local-sentiment).
;; Investors with no nearby tweets experience sentiment decay.
;; =============================================================
to read-local-sentiment
  ask investors [
    ;; Find all tweet agents within vision-radius patches of this investor
    let nearby-tweets tweets in-radius vision-radius
    ifelse any? nearby-tweets [
      ;; Compute influence-weighted average sentiment of visible tweets.
      ;; Higher influence tweets contribute more to what the investor perceives.
      let total-w sum [ tweet-influence ] of nearby-tweets
      set local-sentiment sum [ tweet-sentiment * tweet-influence ] of nearby-tweets
                          / total-w
    ] [
      set local-sentiment local-sentiment * 0.5
    ]
  ]
  ;; Update global average of all investors' perceived sentiment
  ;; (used by the Sensed Sentiment monitor and plot).
  set avg-local-sentiment mean [ local-sentiment ] of investors
end


;; =============================================================
;; DECIDE
;; Investor demand procedure. Calculates each investor's demand value using type-specific equations, then sets their trading state (buy/sell/hold) based on a ±1.5 threshold.
;;
;; Demand Equations (from methodology):
;;   F:  D = 0.3 × (P^f − Pt) + ε
;;   C+: D = γᵢ × local_sentiment × 15 + H × crowd_bias × 5 + ε
;;   C-: D = −γᵢ × local_sentiment × 15 + H × crowd_bias × 5 + ε
;;
;; Scaling factor 15: FinBERT scores are small (max ~0.2). Multiplying by 15 brings them into a range that meaningfully shifts demand above/below the ±1.5 buy/sell threshold.
;; =============================================================
to decide                   ;; investor procedure
  
  ;; ε: Random noise drawn uniformly from [−noise-level, +noise-level].
  ;; Adds stochastic variation to prevent all agents deciding identically.
  let epsilon     ( random-float (2 * noise-level) - noise-level )
  
  ;; Herding pressure: how one-sided the current market is × herding-strength.
  ;; crowd-bias ranges from −1 (all selling) to +1 (all buying).
  ;; Amplified by factor 5 to make herding meaningfully affect demand.
  let herd-push   herding-strength * crowd-bias * 5
  
  ;; Sentiment effect: investor's sensitivity × locally perceived sentiment.
  ;; Scaled by 15 to amplify small FinBERT values into a meaningful range.
  let sent-effect gamma-i * local-sentiment * 15
  
  ;; ── Apply the appropriate demand equation ────────────────
  if agent-type = "F" [
    ;; FUNDAMENTALIST: D^F = 0.3 × (P^f − Pt) + ε
    ;; Buys when market price is below intrinsic value (P^f > Pt).
    ;; Sells when market price is above intrinsic value (P^f < Pt).
    ;; Does NOT use sentiment — stabilising force in the market.
    set demand 0.3 * (price-fundamental - price) + epsilon
  ]

  if agent-type = "C+" [
    ;; OPTIMIST CHARTIST: D^{C+} = γᵢ × local_sentiment × 15 + herd_push + ε
    ;; Buys when nearby tweets are positive.
    ;; Reinforces the crowd direction — primary herding driver.
    set demand sent-effect + herd-push + epsilon
  ]

  if agent-type = "C-" [
    ;; PESSIMIST CHARTIST: D^{C-} = −γᵢ × local_sentiment × 15 + herd_push + ε
    ;; Contrarian to optimists — sells when sentiment is positive.
    ;; Still affected by crowd herding pressure (herd-push term).
    set demand (- sent-effect) + herd-push + epsilon
  ] 
end

;; =============================================================
;; UPDATE-OUTPUT-MEASURES
;; Called at the end of each tick to compute simulation statistics.
;; Computes four output statistics used by monitors and plots.
;; =============================================================
to update-output-measures
  ;; Herding Index: measures how coordinated the market is.
  ;; Takes whichever side (buyers or sellers) is larger as the numerator.
  ;; Range: 0.5 (perfectly balanced) to 1.0 (extreme one-sided herding).
  set herding-index abs (buyers-count - sellers-count) / num-investors
  
  ;; Current Return: percentage price change from last tick to this tick.
  ;; Guards against division by zero if previous-price is ever 0.
  if previous-price != 0 [
    set current-return (price - previous-price) / previous-price
  ]

  ;; Volatility: absolute magnitude of the price return this tick.
  ;; Large volatility = large price movement, regardless of direction.
  set volatility abs current-return
  
  ;; Average Return: cumulative moving average of all returns so far.
  ;; Uses the formula: new_avg = (old_avg × n + new_value) / (n + 1)
  ;; Tracks whether the simulated price drifts up or down overall.
  set average-return ((average-return * ticks) + current-return) / (ticks + 1)
end


;; =============================================================
;; REPORTERS
;; Return computed values to monitors, plots, and other procedures.
to-report crowd-bias
  ;; Reports the net directional bias of all investors this tick.
  ;; Used inside decide to calculate herd-push for chartist agents.
  ;; Range: [−1, 1]
  ;;   +1 = all investors have positive demand (full buying pressure)
  ;;   −1 = all investors have negative demand (full selling pressure)
  ;;    0 = buyers and sellers are perfectly balanced
  let b count investors with [ demand > 0 ]
  let s count investors with [ demand < 0 ]
  report (b - s) / num-investors
end

to-report current-date
  ;; Returns the real-world date string for the current tick.
  ;; Displayed in the Date monitor on the Interface tab.
  ;; Only meaningful when running the dataset scenario.
  ;; "Start" is shown before the first tick runs.
  ;; "Done" is shown after all 36 dates have been processed.
  if ticks = 0                [ report "Start" ]
  if ticks > length date-list [ report "Done"  ]
  report item (ticks - 1) date-list
end

to-report active-tweets
  ;; Returns the count of tweet agents currently alive in the world.
  ;; Displayed in the Active Tweets monitor on the Interface tab.
  ;; Should show up to 10 in dataset mode (top 10 tweets per day).
  ;; Decreases as tweets age and die within tweet-lifespan ticks.
  report count tweets
end]]></code>
  <widgets>
    <view x="395" wrappingAllowedX="true" y="20" frameRate="30.0" minPycor="-16" height="334" showTickCounter="true" patchSize="10.0" fontSize="10" wrappingAllowedY="true" width="334" tickCounterLabel="ticks" maxPycor="16" updateMode="0" maxPxcor="16" minPxcor="-16"></view>
    <button x="20" y="25" height="40" disableUntilTicks="false" forever="false" kind="Observer" width="55" display="Setup">setup</button>
    <button x="270" y="25" height="40" disableUntilTicks="false" forever="true" kind="Observer" width="55" display="Go">go</button>
    <plot x="820" autoPlotX="true" yMax="500.0" autoPlotY="true" yAxis="Price" y="10" xMin="0.0" height="175" legend="false" xMax="40.0" yMin="0.0" width="230" xAxis="Tick (Trading Day)" display="Price Over Time">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="price" color="-13345367" legend="true">
        <setup></setup>
        <update>plot price</update>
      </pen>
    </plot>
    <plot x="820" autoPlotX="true" yMax="100.0" autoPlotY="true" yAxis="Number of Agents" y="200" xMin="0.0" height="175" legend="false" xMax="40.0" yMin="0.0" width="230" xAxis="Tick (Trading Day)" display="Buyers vs Sellers">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="Buyers" color="-13840069" legend="true">
        <setup></setup>
        <update>plot buyers-count</update>
      </pen>
      <pen interval="1.0" mode="0" display="Sellers" color="-8053223" legend="true">
        <setup></setup>
        <update>plot sellers-count</update>
      </pen>
    </plot>
    <plot x="1065" autoPlotX="true" yMax="1.0" autoPlotY="true" yAxis="Return / Volatility" y="10" xMin="0.0" height="175" legend="false" xMax="40.0" yMin="-1.0" width="230" xAxis="Tick (Trading Day)" display="Returns / Volatility">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="Return" color="-13840069" legend="true">
        <setup></setup>
        <update>plot current-return</update>
      </pen>
      <pen interval="1.0" mode="0" display="Volatility" color="-2674135" legend="true">
        <setup></setup>
        <update>plot volatility</update>
      </pen>
    </plot>
    <button x="125" y="25" height="40" disableUntilTicks="false" forever="false" kind="Observer" width="65" display="Go Once">go-once</button>
    <slider x="10" step="10" y="75" max="100" width="150" display="num-investors" height="50" min="10" direction="Horizontal" default="50.0" variable="num-investors"></slider>
    <slider x="170" step="1" y="75" max="100" width="165" display="num-fundamentalists" height="50" min="0" direction="Horizontal" default="30.0" variable="num-fundamentalists"></slider>
    <slider x="10" step="0.05" y="130" max="1" width="150" display="herding-strength" height="50" min="0" direction="Horizontal" default="0.6" variable="herding-strength"></slider>
